<svg xmlns="http://www.w3.org/2000/svg" width="420" height="520" viewBox="0 0 420 520">
  <defs>
    <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#F5EDD8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#FAF3E0;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="gold" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#A07830;stop-opacity:1" />
      <stop offset="50%" style="stop-color:#C9A84C;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E8C97A;stop-opacity:1" />
    </linearGradient>
    <clipPath id="circle">
      <circle cx="210" cy="200" r="100"/>
    </clipPath>
  </defs>

  <!-- Background -->
  <rect width="420" height="520" fill="url(#bg)" rx="24"/>

  <!-- Decorative border -->
  <rect x="12" y="12" width="396" height="496" fill="none" stroke="#C9A84C" stroke-width="1.5" rx="18" stroke-dasharray="6 4" opacity="0.4"/>

  <!-- Circle avatar bg -->
  <circle cx="210" cy="200" r="108" fill="url(#gold)" opacity="0.15"/>
  <circle cx="210" cy="200" r="100" fill="url(#gold)" opacity="0.12"/>

  <!-- Person silhouette -->
  <circle cx="210" cy="178" r="46" fill="url(#gold)" opacity="0.7"/>
  <ellipse cx="210" cy="310" rx="78" ry="55" fill="url(#gold)" opacity="0.55"/>

  <!-- Gold ring -->
  <circle cx="210" cy="200" r="104" fill="none" stroke="url(#gold)" stroke-width="2.5" opacity="0.5"/>

  <!-- Upload instruction text -->
  <text x="210" y="390" text-anchor="middle" font-family="Jost, sans-serif" font-size="13" fill="#A07830" font-weight="600" letter-spacing="1">YOUR PHOTO HERE</text>
  <text x="210" y="412" text-anchor="middle" font-family="Jost, sans-serif" font-size="11" fill="#9A9A9A">Replace images/profile.jpg</text>

  <!-- Small camera icon -->
  <g transform="translate(188, 435)">
    <rect x="0" y="0" width="44" height="32" rx="6" fill="#C9A84C" opacity="0.2"/>
    <circle cx="22" cy="16" r="8" fill="#C9A84C" opacity="0.5"/>
    <circle cx="22" cy="16" r="4" fill="#C9A84C" opacity="0.9"/>
  </g>

  <!-- Corner decorations -->
  <line x1="20" y1="30" x2="40" y2="30" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="30" y1="20" x2="30" y2="40" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="380" y1="30" x2="400" y2="30" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="390" y1="20" x2="390" y2="40" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="20" y1="490" x2="40" y2="490" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="30" y1="480" x2="30" y2="500" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="380" y1="490" x2="400" y2="490" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
  <line x1="390" y1="480" x2="390" y2="500" stroke="#C9A84C" stroke-width="1.5" opacity="0.5"/>
</svg>
